dir=$FLS_PATH/xpg

alias find='php $dir/find.php'
alias tab='php $dir/tabs.php'
alias tabs='php $dir/tabs.php'
alias clear='rm $dir/data/{state,t[0-9]*}.json'
alias view='php $dir/view.php'
alias pull='php $dir/pull.php'
alias scan='php $dir/scan.php'
alias copy='cb $dir/data/view.json'
alias cols='php $dir/cols.php'
alias our='php $dir/our.php'
alias rels='php $dir/rels.php'
alias tables='php $dir/tables.php'

script() {
    LAST_SCRIPT=$dir/data/script$1.php
    if [[ ! -f "$LAST_SCRIPT" ]]; then
        cp $dir/script.php $LAST_SCRIPT
    fi;
    nano $LAST_SCRIPT
    php $LAST_SCRIPT
}

