dir=$FLS_PATH/xpg
data_dir=${XPG_DATA_DIR:-data}

alias find='php $dir/find.php'
alias tab='php $dir/tabs.php'
alias tabs='php $dir/tabs.php'
alias flush='rm $data_dir/{state,t[0-9]*}.json'
alias view='php $dir/view.php'
alias pull='php $dir/pull.php'
alias scan='php $dir/scan.php'
alias copy='cb $data_dir/view.json'
alias cols='php $dir/cols.php'
alias our='php $dir/our.php'
alias rels='php $dir/rels.php'
alias tables='php $dir/tables.php'
alias update='php $dir/update.php'
alias del='php $dir/del.php'
alias keep='php $dir/keep.php'

script() {
    LAST_SCRIPT=$data_dir/script$1.php
    if [[ ! -f "$LAST_SCRIPT" ]]; then
        cp $data_dir/script.php $LAST_SCRIPT
    fi;
    nano $LAST_SCRIPT
    php $LAST_SCRIPT
}

input() {
    echo "" > /tmp/input
    echo "" > $data_dir/input.json
    nano /tmp/input
    if jq -e . /tmp/input >/dev/null 2>&1; then
      mv /tmp/input $data_dir/input.json
    else
      php $dir/parse.php
    fi
    
    cat $data_dir/input.json
}

ifind() {
    input
    find $1 @i
}
